{
  "name": "relay-rpg",
  "private": true,
  "version": "1.0.0",
  "description": "A collaborative storytelling RPG system where players pass narrative control like a relay race",
  "main": "app.js",
  "type": "module",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "start": "tsx app.js",
    "register": "tsx commands.js",
    "dev": "tsx watch app.js",
    "typecheck": "tsc --noEmit"
  },
  "author": "Shay DeWael",
  "license": "MIT",
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.0",
    "better-sqlite3": "^12.9.0",
    "discord-interactions": "^4.0.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
